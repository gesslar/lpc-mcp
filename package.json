{
  "name": "@gesslar/lpc-mcp",
  "description": "MCP server for LPC language server",
  "author": {
    "name": "gesslar",
    "url": "https://gesslar.dev"
  },
  "version": "1.6.1",
  "license": "0BSD",
  "homepage": "https://github.com/gesslar/lpc-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gesslar/lpc-mcp.git"
  },
  "keywords": [
    "fluffos",
    "lpc",
    "mud",
    "mcp",
    "model-context-protocol",
    "shlemiel",
    "schlemazel",
    "hasenpfeffer",
    "incorporated"
  ],
  "main": "index.js",
  "type": "module",
  "bin": {
    "lpc-mcp": "./src/index.js"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "types:build": "tsc -p tsconfig.types.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "submit": "npm publish --access public --//registry.npmjs.org/:_authToken=\"${NPM_ACCESS_TOKEN}\"",
    "update": "npx npm-check-updates -u && npm install",
    "pr": "gt submit -p --ai",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major"
  },
  "dependencies": {
    "@gesslar/toolkit": "^5.0.1",
    "@gesslar/uglier": "^2.4.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "vscode-jsonrpc": "^8.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "eslint": "^10.2.0"
  }
}
